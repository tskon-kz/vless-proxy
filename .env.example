# =============================================================================
# VLESS Proxy Manager — environment variables example
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram (required)
# -----------------------------------------------------------------------------

# Bot token from @BotFather
TG_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Comma-separated list of Telegram user IDs allowed to control the bot
TG_ALLOWED_USER_IDS=123456789,987654321

# -----------------------------------------------------------------------------
# xray-core
# -----------------------------------------------------------------------------

# Path to the xray binary (installed by install-xray.sh)
XRAY_BINARY=/usr/local/bin/xray

# Directory where temporary xray config files are written
XRAY_CONFIG_DIR=/tmp/vless-manager

# -----------------------------------------------------------------------------
# Proxy pool (SOCKS5 ports allocated for running xray instances)
# -----------------------------------------------------------------------------

# First port in the pool (inclusive)
PROXY_PORT_START=10800

# Last port in the pool (inclusive)
PROXY_PORT_END=10820

# Address that SOCKS5 listeners bind to
PROXY_BIND_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Health check
# -----------------------------------------------------------------------------

# URL to verify connectivity through a proxy — should be blocked in Russia
CHECK_URL=https://www.linkedin.com

# Seconds to wait for a single health check request
CHECK_TIMEOUT=10

# Seconds between periodic background health checks of the whole pool
CHECK_INTERVAL=300

# Seconds to wait after launching an xray process before running the first check
CHECK_STARTUP_XRAY_WAIT=2

# -----------------------------------------------------------------------------
# REST API
# -----------------------------------------------------------------------------

# Address the FastAPI server listens on
API_HOST=127.0.0.1

# Port the FastAPI server listens on
API_PORT=8888

# Secret key for POST /update endpoint (leave empty to disable the endpoint)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Path to the SQLite database file
DB_PATH=./state.db

# -----------------------------------------------------------------------------
# File watcher
# -----------------------------------------------------------------------------

# Path to the fallback file containing VLESS links (one per line)
VLESS_FILE=./vless.txt

# Seconds between checks for changes to VLESS_FILE
FILE_CHECK_INTERVAL=30
