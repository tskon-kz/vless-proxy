# =============================================================================
# VLESS Proxy Manager — environment variables example
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram (required)
# -----------------------------------------------------------------------------

# Bot token from @BotFather
TG_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Comma-separated list of Telegram user IDs allowed to control the bot
TG_ALLOWED_USER_IDS=[123456789,987654321]

# Chat ID to send notifications when a proxy goes alive or dead (optional)
TG_NOTIFY_CHAT_ID=

# Proxy for outgoing Telegram API requests (optional).
# Use when the server cannot reach Telegram directly.
# Point to one of the SOCKS5 ports from your own proxy pool:
#   TG_BOT_PROXY=socks5://127.0.0.1:10800
TG_BOT_PROXY=

# -----------------------------------------------------------------------------
# Subscriptions
# -----------------------------------------------------------------------------

# JSON array of subscription URLs to poll every 30 minutes.
# The service fetches all vless:// links from each URL and keeps them in the DB.
# Example: SUBSCRIPTION_URLS=["https://example.com/sub1","https://example.com/sub2"]
SUBSCRIPTION_URLS=[]

# How often (seconds) to refresh subscriptions. Default: 1800 (30 min)
SUBSCRIPTION_FETCH_INTERVAL=1800

# -----------------------------------------------------------------------------
# xray-core
# -----------------------------------------------------------------------------

# Path to the xray binary (installed by scripts/install-xray.sh)
XRAY_BINARY=/usr/local/bin/xray

# Directory where temporary xray config files are written
XRAY_CONFIG_DIR=/tmp/vless-manager

# -----------------------------------------------------------------------------
# Proxy pool (SOCKS5 ports allocated for running xray instances)
# -----------------------------------------------------------------------------

# Port range for the proxy pool (inclusive).
# The fastest proxy is always on PROXY_PORT_START.
PROXY_PORT_START=10800
PROXY_PORT_END=10850

# Address that SOCKS5 listeners bind to
PROXY_BIND_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Health check
# -----------------------------------------------------------------------------

# URL used to verify connectivity — should be reachable only through a proxy
CHECK_URL=https://www.linkedin.com

# Seconds to wait for a single health check request
CHECK_TIMEOUT=10

# Seconds between periodic health check cycles
CHECK_INTERVAL=300

# Seconds to wait after launching xray before running the first check
CHECK_STARTUP_XRAY_WAIT=2

# -----------------------------------------------------------------------------
# REST API
# -----------------------------------------------------------------------------

# Address the FastAPI server listens on
API_HOST=127.0.0.1

# Port the FastAPI server listens on
API_PORT=8888

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Path to the SQLite database file
DB_PATH=./state.db
